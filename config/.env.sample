# Minipupper Operator - Environment Variables
# Copy this file to .env and fill in your actual values
# Last Updated: 2026-05-09

# ============================================
# Google Cloud Configuration
# ============================================

# Path to Google Cloud service account key
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Create a key with permissions:
#   - Cloud Speech-to-Text API
#   - Cloud Text-to-Speech API
#   - Vertex AI API (for Gemini)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Google Cloud Project ID
# Found in: https://console.cloud.google.com/projectsettings
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# ============================================
# Audio Configuration
# ============================================

# Audio device selection (-1 = default device)
# List devices with: python -c "import sounddevice; print(sounddevice.query_devices())"
AUDIO_DEVICE_INDEX=-1
MIC_SAMPLE_RATE=16000
MIC_CHANNELS=1
SPEAKER_DEVICE_INDEX=-1

# ============================================
# ASR (Speech-to-Text) Configuration
# ============================================

# ASR engine: "google" (Google Cloud Speech-to-Text, recommended)
#             "whisper" (local Whisper model, offline)
ASR_ENGINE=google

# If using Whisper fallback:
# Model size: tiny, base, small, medium, large
WHISPER_MODEL=base
WHISPER_DEVICE=cpu  # cpu or cuda

# ============================================
# LLM Configuration
# ============================================

# LLM Provider: "gemini" (Google Gemini via Vertex AI, recommended)
#               "ollama" (local Ollama server)
#               "fallback" (simple template responses)
LLM_PROVIDER=gemini

# Gemini model: gemini-1.5-flash (fast, recommended)
#               gemini-1.5-pro (more capable)
#               gemini-2.0-flash (cutting edge)
LLM_MODEL=gemini-1.5-flash

# If using Ollama:
# URL to Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ============================================
# Barge-in Configuration (optional, overrides config.yaml)
# ============================================

BARGE_IN_ENABLED=true

# Energy threshold for speech detection
# Lower = more sensitive, Higher = less sensitive
# Typical range: 300-800
# Quiet environment: 300, Normal: 500, Noisy: 800
BARGE_IN_THRESHOLD=500

# ============================================
# Debugging & Logging
# ============================================

DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Network Configuration
# ============================================

# OpenClaw Gateway URL (Tailscale TLS WebSocket)
# Format: wss://instance-hostname.tail{xxxxx}.ts.net:443
OPENCLAW_GATEWAY_URL=wss://your-gateway-hostname.ts.net:443

# Tailscale Authentication
# Get from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=tskey-xxxxxxxxxxxx
TAILSCALE_HOSTNAME=minipupper-operator

# ============================================
# Optional: Cloud API Keys (if not using Google Cloud)
# ============================================

# OpenAI API Key (for ChatGPT, not currently used)
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ElevenLabs API Key (for premium TTS, not currently used)
# ELEVENLABS_API_KEY=xxxxxxxxxxxx
